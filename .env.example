DATABASE_URL=postgresql+psycopg://risk_user:risk_password@localhost:5432/market_risk
SCHEDULER_DATABASE_URL=postgresql+psycopg://risk_user:risk_password@postgres:5432/market_risk
RISK_FREE_RATE_ANNUAL=0.02
PRICE_SOURCE=yfinance
# sample, live, live_with_fallback, or database
MARKET_DATA_MODE=sample

# Docker Compose scheduler defaults
ETL_DAILY_AT=06:00
# Used only when ETL_DAILY_AT is unset.
ETL_INTERVAL_MINUTES=1440
ETL_TIMEZONE=America/Edmonton
ETL_RUN_ON_START=true
ETL_LOAD_DB=true
ETL_LIVE=true
ETL_NO_WRITE=true
ETL_LOG_LEVEL=INFO
